# Test account safety: allowlisted accounts for E2E and integration tests.
# Tests crash immediately if ONEDRIVE_ALLOWED_TEST_ACCOUNTS is not set or
# if ONEDRIVE_TEST_DRIVE is not in the allowlist. This prevents accidental
# runs against production accounts.
#
# Copy this file to .env and fill in your test account details.
# The .env file is gitignored and loaded automatically by test harnesses.
# Durable shared-item fixtures belong in .testdata/fixtures.env instead.
#
# Test credentials (tokens + config) live in .testdata/ (gitignored).
# Run scripts/bootstrap-test-credentials.sh to populate .testdata/.

# Comma-separated list of allowed test accounts (required).
ONEDRIVE_ALLOWED_TEST_ACCOUNTS=personal:your-account@outlook.com

# Test drive used when running E2E or integration tests locally (required).
ONEDRIVE_TEST_DRIVE=personal:your-account@outlook.com

# Second test drive for multi-drive E2E tests (optional).
# Multi-drive tests skip gracefully when this is empty.
# ONEDRIVE_TEST_DRIVE_2=personal:second-account@outlook.com

# Durable shared-item fixtures should be stored in .testdata/fixtures.env,
# which is gitignored, shared into worktrees via the .testdata symlink, and
# synced to CI via scripts/migrate-test-data-to-ci.sh. Example:
#   ONEDRIVE_TEST_SHARED_LINK=https://1drv.ms/...
#   ONEDRIVE_TEST_SHARED_FOLDER_LINK=https://1drv.ms/...
#   ONEDRIVE_TEST_WRITABLE_SHARED_FOLDER=shared:second-account@outlook.com:<driveId>:<itemId>
#   ONEDRIVE_TEST_READONLY_SHARED_FOLDER=shared:second-account@outlook.com:<driveId>:<itemId>
#
# Root .env can still override the shared link locally when needed, but it is
# not the durable source of truth.

# Optional raw shared-folder link used to prove `drive add <share-url>`
# normalizes to the same canonical shared drive as the writable selector
# fixture. Keep this in .testdata/fixtures.env, not root .env.
# ONEDRIVE_TEST_SHARED_FOLDER_LINK=https://1drv.ms/...

# Writable shared-folder selector used by the full shared-folder sync E2E suite.
# The selector must resolve to a folder visible in one configured recipient
# account's `shared --json` catalog.
# ONEDRIVE_TEST_WRITABLE_SHARED_FOLDER=shared:second-account@outlook.com:<driveId>:<itemId>

# Read-only shared-folder selector used by the blocked-write shared-folder E2E
# suite. The selector must resolve to a folder visible in one configured
# recipient account's `shared --json` catalog.
# ONEDRIVE_TEST_READONLY_SHARED_FOLDER=shared:second-account@outlook.com:<driveId>:<itemId>
